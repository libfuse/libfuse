[Unit]
Description=Socket for service_ll Service

[Socket]
# Typically the socket path is /run/filesystems/service_ll
ListenSequentialPacket=@FUSE_SERVICE_SOCKET_DIR_RAW@/service_ll
Accept=yes
SocketMode=0660
RemoveOnStop=yes

[Install]
WantedBy=sockets.target
