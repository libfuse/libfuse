[Unit]
Description=Socket for null Service

[Socket]
ListenSequentialPacket=@FUSE_SERVICE_SOCKET_DIR_RAW@/null
Accept=yes
SocketMode=@FUSE_SERVICE_SOCKET_PERMS@
RemoveOnStop=yes

[Install]
WantedBy=sockets.target
